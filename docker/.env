# ZooKeeper-based setup (Kafka 3.x — ZooKeeper support removed in 4.0)
KAFKA_VERSION=3.9.2
# KRaft-based setup (Kafka 4.x — no ZooKeeper, process.roles required)
KAFKA_KRAFT_VERSION=4.1.1

SCALA_VERSION=2.13
KAFKA_ARCHIVE=kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz
KAFKA_IMAGE=kafka:local
KAFKA_RAFT_IMAGE=kafka-raft:local
KAFKA_CONTAINER_NAME=kafka